# LLM Providers (ANTHROPIC YO'Q)
GROQ_API_KEY=your-groq-key
GEMINI_API_KEY=your-gemini-key
OLLAMA_BASE_URL=https://your-hf-server.hf.space   # HuggingFace endpoint

# Infrastructure
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://acap:acap_secret@postgres:5432/acap_db
AUTH_SERVICE_URL=http://auth-service:8000
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
DEBUG=true

# LLM Config
PRIMARY_PROVIDER=groq          # groq | gemini | ollama
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_MODEL=qwen2.5-coder:7b  # yoki serverda o'rnatilgan model nomi
